{
  "manifest_version": 3,
  "name": "My Extension",
  "version": "1.0.0",
  "description": "Baseline Chrome extension (Manifest V3).",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://api.datamuse.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "My Extension"
  },
  "background": {
    "service_worker": "background.js"
  }
}
